# ──────────────────────────────────────────────────────────────
# UrbanFlow SmartRoute — Variables d'environnement
# ──────────────────────────────────────────────────────────────

# Base de données
DATABASE_URL=postgresql://user:password@localhost:5432/urbanflow

# Transport provider : transitous | otp | demo
TRANSPORT_PROVIDER=demo

# Mode démo — surcharge tous les appels API externes vers demo-data/
DEMO_MODE=true

# Transitous (production cloud)
TRANSITOUS_URL=https://api.transitous.org/api/

# OTP — Open Trip Planner (développement local)
OTP_URL=http://localhost:8080

# OpenWeatherMap
OPENWEATHER_API_KEY=

# Auth JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-too-in-production-min-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Serveur Express
PORT=3000
NODE_ENV=development

# CORS — doit correspondre à l'URL du frontend
CORS_ORIGIN=http://localhost:5173
